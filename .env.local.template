# ─── Supabase ─────────────────────────────────────────────────
# Obten estos valores en: https://supabase.com > tu proyecto > Settings > API
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_ANON_KEY=tu-anon-key-publica

# ─── OpenAI (Asistente de IA) ─────────────────────────────────
# Solo en el backend (apps/api) — nunca exponer en el frontend
# OPENAI_API_KEY=sk-...

# ─── Culqi (Pagos) ────────────────────────────────────────────
# Llave publica para el frontend (inicializar el formulario de pago)
VITE_CULQI_PUBLIC_KEY=pk_test_...

# ─── PrintNode (Impresion) ────────────────────────────────────
# Solo en el backend — nunca exponer en el frontend
# PRINTNODE_API_KEY=...

# ─── App ──────────────────────────────────────────────────────
VITE_APP_URL=http://localhost:5173
